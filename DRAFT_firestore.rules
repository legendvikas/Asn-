rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      // Bootstrapped admin check + database check
      return isVerified() && (
        request.auth.token.email == 'ffdiwana24@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isTeacher() {
      return isVerified() && getUserRole() == 'teacher';
    }

    function isStudent() {
      return isVerified() && getUserRole() == 'student';
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.role in ['admin', 'teacher', 'student'] &&
             data.displayName is string && data.displayName.size() <= 100;
    }

    function isValidClass(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100;
    }

    function isValidAttendance(data) {
      return data.keys().hasAll(['date', 'classId', 'records']) &&
             data.date is string && data.classId is string &&
             data.records is map;
    }

    function isValidAssignment(data) {
      return data.keys().hasAll(['title', 'classId', 'teacherId', 'dueDate', 'createdAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.teacherId == request.auth.uid &&
             data.createdAt == request.time &&
             exists(/databases/$(database)/documents/classes/$(data.classId));
    }

    function isValidResult(data) {
      return data.keys().hasAll(['studentId', 'subject', 'marks', 'totalMarks']) &&
             data.marks is number && data.totalMarks is number &&
             data.marks >= 0 && data.marks <= data.totalMarks &&
             exists(/databases/$(database)/documents/users/$(data.studentId));
    }

    function isValidFee(data) {
      return data.keys().hasAll(['studentId', 'amount', 'status']) &&
             data.amount is number && data.status in ['paid', 'unpaid'];
    }

    function isValidAnnouncement(data) {
      return data.keys().hasAll(['title', 'content', 'targetRole', 'createdAt', 'authorId']) &&
             data.title is string && data.title.size() <= 200 &&
             data.authorId == request.auth.uid &&
             data.createdAt == request.time;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isVerified() && isValidId(userId) && isValidUser(incoming()) && (
        // Only allow first-time creation of self with 'student' role unless admin
        incoming().role == 'student' || isAdmin()
      );
      allow update: if isVerified() && (
        isAdmin() || (
          request.auth.uid == userId &&
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])
        )
      );
      allow delete: if isAdmin();
    }

    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() && isValidId(classId);
    }

    match /attendance/{atId} {
      allow read: if (isTeacher() || isStudent() || isAdmin()) && isValidId(atId);
      allow create, update: if (isAdmin() || isTeacher()) && isValidId(atId) && isValidAttendance(incoming());
      allow delete: if isAdmin() && isValidId(atId);
    }

    match /assignments/{asId} {
      allow read: if isSignedIn() && isValidId(asId);
      allow create: if (isAdmin() || isTeacher()) && isValidId(asId) && isValidAssignment(incoming());
      allow update: if (isAdmin() || (isTeacher() && existing().teacherId == request.auth.uid)) &&
                    isValidId(asId) &&
                    isValidAssignment(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'dueDate']);
      allow delete: if (isAdmin() || (isTeacher() && existing().teacherId == request.auth.uid)) && isValidId(asId);
    }

    match /results/{resId} {
      allow read: if (isStudent() && existing().studentId == request.auth.uid || isTeacher() || isAdmin()) && isValidId(resId);
      allow create, update: if (isAdmin() || isTeacher()) && isValidId(resId) && isValidResult(incoming());
      allow delete: if isAdmin() && isValidId(resId);
    }

    match /fees/{feeId} {
      allow read: if (isStudent() && existing().studentId == request.auth.uid || isAdmin()) && isValidId(feeId);
      allow create, delete: if isAdmin() && isValidId(feeId);
      allow update: if isAdmin() && isValidId(feeId) && isValidFee(incoming());
    }

    match /announcements/{annId} {
      allow read: if isSignedIn() && isValidId(annId);
      allow create: if (isAdmin() || isTeacher()) && isValidId(annId) && isValidAnnouncement(incoming());
      allow update: if (isAdmin() || (isTeacher() && existing().authorId == request.auth.uid)) &&
                    isValidId(annId) &&
                    isValidAnnouncement(incoming());
      allow delete: if (isAdmin() || (isTeacher() && existing().authorId == request.auth.uid)) && isValidId(annId);
    }
  }
}
