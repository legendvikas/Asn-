{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users (Admin or Parent)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "parent"] },
        "studentId": { "type": "string", "description": "For parents, the ID of their child" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Student": {
      "title": "Student",
      "description": "Student record",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "class": { "type": "string" },
        "contact": { "type": "string" },
        "parentEmail": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "class"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily attendance record",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "studentId": { "type": "string" },
        "status": { "type": "string", "enum": ["present", "absent"] }
      },
      "required": ["date", "studentId", "status"]
    },
    "Result": {
      "title": "Result",
      "description": "Examination results",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "subject": { "type": "string" },
        "marks": { "type": "number" },
        "totalMarks": { "type": "number" },
        "term": { "type": "string" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["studentId", "subject", "marks", "totalMarks"]
    },
    "Fee": {
      "title": "Fee",
      "description": "Fee payment records",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "unpaid"] },
        "dueDate": { "type": "string", "format": "date" },
        "month": { "type": "string" }
      },
      "required": ["studentId", "amount", "status", "month"]
    },
    "Teacher": {
      "title": "Teacher",
      "description": "Staff record",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "contact": { "type": "string" },
        "assignedClass": { "type": "string" },
        "subjects": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email"]
    },
    "Settings": {
      "title": "Settings",
      "description": "School information",
      "type": "object",
      "properties": {
        "schoolName": { "type": "string" },
        "contact": { "type": "string" },
        "address": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "System user profiles" },
    "students": { "schema": "Student", "description": "Student details" },
    "attendance": { "schema": "Attendance", "description": "Attendance history" },
    "results": { "schema": "Result", "description": "Student performance" },
    "fees": { "schema": "Fee", "description": "Financial records" },
    "teachers": { "schema": "Teacher", "description": "Staff details" },
    "settings": { "schema": "Settings", "description": "School configuration" }
  }
}
