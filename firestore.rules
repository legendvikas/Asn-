rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'ffdiwana24@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isParentOf(studentId) {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn() && user.role == 'parent' && user.studentId == studentId;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /students/{studentId} {
      allow read: if isAdmin() || isParentOf(studentId);
      allow write: if isAdmin();
    }

    match /attendance/{id} {
      allow read: if isAdmin() || isParentOf(resource.data.studentId);
      allow write: if isAdmin();
    }

    match /results/{id} {
      allow read: if isAdmin() || isParentOf(resource.data.studentId);
      allow write: if isAdmin();
    }

    match /fees/{id} {
      allow read: if isAdmin() || isParentOf(resource.data.studentId);
      allow write: if isAdmin();
    }

    match /teachers/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
